[debug] [2026-06-06T05:40:38.984Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/japanese-flashcard-fa23d/rulesets {"name":"projects/japanese-flashcard-fa23d/rulesets/974a2648-2268-402c-82da-be77c0be730f","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    function isValidPackage() {\n      let data = request.resource.data;\n      let allowed = [\"name\", \"description\", \"language\", \"cardCount\", \"createdAt\", \"updatedAt\"];\n      return data.keys().hasOnly(allowed)\n        && data.name is string && data.name.size() > 0\n        && data.description is string\n        && data.language is string\n        && data.cardCount is number\n        && data.createdAt is timestamp\n        && data.updatedAt is timestamp;\n    }\n\n    function isValidFlashcard() {\n      let data = request.resource.data;\n      let allowed = [\n        \"vocab\", \"kana\", \"furigana\", \"defs\", \"kanji\", \"pos\",\n        \"register\", \"context\", \"grammar_notes\", \"phrases\",\n        \"examples\", \"synonyms\", \"antonyms\", \"updatedAt\"\n      ];\n      return data.keys().hasOnly(allowed)\n        && data.vocab is string && data.vocab.size() > 0\n        && data.kana is list\n        && data.furigana is list\n        && data.defs is list\n        && data.kanji is list\n        && data.pos is list\n        && data.register is list\n        && data.context is string\n        && data.grammar_notes is list\n        && data.phrases is list\n        && data.examples is list\n        && data.synonyms is list\n        && data.antonyms is list;\n    }\n\n    function isValidMetadata() {\n      let data = request.resource.data;\n      let allowed = [\"vocab\", \"romaji\", \"jlpt\", \"grammar\", \"pitch_data\", \"frequency\", \"updatedAt\"];\n      return data.keys().hasOnly(allowed)\n        && data.vocab is string && data.vocab.size() > 0\n        && data.romaji is string\n        && data.jlpt is string\n        && data.grammar is bool\n        && data.pitch_data is list\n        && data.frequency is map;\n    }\n\n    match /packages/{packageId} {\n      allow read: if isAuthenticated();\n      allow create: if isAuthenticated() && isValidPackage();\n      allow update: if isAuthenticated();\n      allow delete: if isAuthenticated();\n\n      match /cards/{vocab} {\n        allow read: if isAuthenticated();\n        allow write: if isAuthenticated() && isValidFlashcard();\n      }\n    }\n\n    match /metadata/{vocab} {\n      allow read: if isAuthenticated();\n      allow write: if isAuthenticated() && isValidMetadata();\n    }\n\n    match /user_profiles/{userId} {\n    allow list: if request.auth != null;\n    allow read, write: if request.auth != null && request.auth.uid == userId;\n    }\n\n    function isActiveUser() {\n      let profile = get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;\n      return (profile.account_type == \"paid\" && profile.subscription_status == \"active\")\n          || (profile.account_type == \"anon\" && profile.anon_expires_at > request.time)\n          || profile.account_type == \"email\";\n    }\n\n    match /flashcards/{doc} {\n      allow read: if true;\n    }\n\n    match /usernames/{username} {\n        allow read: if true;\n        allow write: if false;\n    }\n\n    match /audio_speakers/{speaker} {\n      allow read: if true;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-06T05:40:39.697903Z","metadata":{"services":["cloud.firestore"]}}
